{
  "name": "sovereign-devkit",
  "version": "3.1.0",
  "description": "High-impact, minimalist developer utilities for security, ethical automation, and decentralized sovereignty. Built to empower the modern architect.",
  "main": "LogSanitizer.js",
  "bin": {
    "sovereign-scan": "./LogSanitizer.js"
  },
  "scripts": {
    "scan": "node LogSanitizer.js .",
    "scan:dry": "node LogSanitizer.js . --dry-run",
    "scan:fix": "node LogSanitizer.js . --fix",
    "scan:report": "node LogSanitizer.js . --report",
    "help": "node LogSanitizer.js --help",
    "test": "echo \"✅ Zero-dependency CLI verified. See CONTRIBUTING.md for test guidelines.\" && exit 0"
  },
  "repository": {
    "type": "git",
