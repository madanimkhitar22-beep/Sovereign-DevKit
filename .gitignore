# ═══════════════════════════════════════════
#  Sovereign-DevKit — .gitignore (v3.1)
#  Minimalist • Mobile-First • Security-Focused
# ═══════════════════════════════════════════

# ── Dependencies ───────────────────────────
node_modules/

# ── Runtime & Logs ─────────────────────────
*.log
npm-debug.log*
logs/

# ── Sovereign-DevKit Generated Files ───────
# Auto-backups from --fix --backup (user choice to track or ignore)
*.bak

# Audit reports from --report flag
report.json

# Future: Signed audit files (v4.0+)
*.sig

# User policy file (keep example tracked)
.sovereign-policy
!.sovereign-policy.example

# ── Environment & Secrets ──────────────────
.env
.env.local
.env.*.local
!.env.example

# ── OS & Editor ────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json

# ── Termux / Mobile-Specific ───────────────
# Optional: ignore Termux session files if created
.termux/session.state

# ── Build / Cache (if ever needed) ─────────
.cache/
*.tsbuildinfo

# ── Output / Temp ──────────────────────────
*.tgz
temp/
tmp/
